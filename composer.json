{
    "name": "sphere/eshop",
    "description": "SPHERE Shoe E-Commerce — Nette 3.2",
    "require": {
        "php": ">=8.2",
        "nette/application": "^3.2",
        "nette/bootstrap": "^3.2",
        "nette/database": "^3.2",
        "nette/di": "^3.2",
        "nette/forms": "^3.2",
        "nette/http": "^3.2",
        "nette/routing": "^3.1",
        "nette/security": "^3.2",
        "nette/utils": "^4.0",
        "latte/latte": "^3.0",
        "tracy/tracy": "^2.10"
    },
    "require-dev": {
        "nette/tester": "^2.5"
    },
    "autoload": {
