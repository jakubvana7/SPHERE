<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{ifset title}{include title} | {/ifset}SPHERE</title>
    <meta name="description" content="SPHERE — premium shoe store">
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['"Helvetica Neue"', 'Arial', 'sans-serif'] },
                    letterSpacing: { widest: '0.3em' },
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Roboto', 'Helvetica Neue', Arial, sans-serif; }
        #search-overlay { transition: opacity 0.2s ease; }
    </style>
</head>
<body class="bg-white text-black min-h-screen flex flex-col">

<!-- Navigation -->
<header class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-100">
    <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

        <!-- Left: categories -->
        <div class="flex gap-10 w-1/3">
            <a href="{link Men:default}" class="text-[11px] font-bold tracking-[0.2em] uppercase hover:opacity-40 transition-opacity">Men</a>
            <a href="{link Women:default}" class="text-[11px] font-bold tracking-[0.2em] uppercase hover:opacity-40 transition-opacity">Women</a>
        </div>

        <!-- Center: logo -->
        <a href="{link Homepage:default}" id="logo-link" class="text-2xl font-black tracking-[0.4em] hover:opacity-50 transition-opacity absolute left-1/2 -translate-x-1/2">SPHERE</a>

        <!-- Right: actions -->
        <div class="flex gap-8 items-center justify-end w-1/3">

            <!-- Search icon -->
            <button id="search-btn" aria-label="Search" class="hover:opacity-40 transition-opacity">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
                </svg>
            </button>

            <!-- Cart -->
            <a href="{link Cart:default}" class="relative hover:opacity-40 transition-opacity">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
                {if $cartCount > 0}
                <span class="absolute -top-2 -right-2.5 bg-black text-white text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center leading-none">{$cartCount}</span>
                {/if}
            </a>

            <!-- Account -->
            {if $user->isLoggedIn()}
                {if $user->isInRole('admin')}
                <div class="relative" id="admin-menu-wrap">
                    <button id="admin-menu-btn" class="text-[11px] font-bold tracking-[0.2em] uppercase hover:opacity-40 transition-opacity text-gray-400 flex items-center gap-1">
                        Admin
                        <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="admin-menu" class="hidden absolute right-0 top-full mt-3 w-44 bg-white border border-gray-100 shadow-xl z-50">
                        <a href="{link Admin:default}" class="block px-5 py-3.5 text-[11px] font-bold tracking-[0.15em] uppercase hover:bg-gray-50 transition-colors">Dashboard</a>
                        <div class="border-t border-gray-100"></div>
                        <a href="{link Sign:out}" class="block px-5 py-3.5 text-[11px] font-bold tracking-[0.15em] uppercase text-gray-400 hover:bg-gray-50 transition-colors">Logout</a>
                    </div>
                </div>
                {else}
                {var $firstName = explode(' ', $user->getIdentity()->data['name'] ?? '', 2)[0]}
                <div class="relative" id="user-menu-wrap">
                    <button id="user-menu-btn" class="text-[11px] font-bold tracking-[0.2em] uppercase hover:opacity-40 transition-opacity flex items-center gap-1">
                        {$firstName}
                        <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="user-menu" class="hidden absolute right-0 top-full mt-3 w-52 bg-white border border-gray-100 shadow-xl z-50">
                        <div class="px-5 py-4 border-b border-gray-100">
                            <p class="text-xs font-bold">{$user->getIdentity()->data['name'] ?? ''}</p>
                            <p class="text-[11px] text-gray-400 mt-0.5">{$user->getIdentity()->data['email'] ?? ''}</p>
                        </div>
                        <a href="{link Account:default}" class="block px-5 py-3.5 text-[11px] font-bold tracking-[0.15em] uppercase hover:bg-gray-50 transition-colors">My Orders</a>
                        <a href="{link Account:default}" class="block px-5 py-3.5 text-[11px] font-bold tracking-[0.15em] uppercase hover:bg-gray-50 transition-colors">Account Settings</a>
                        <div class="border-t border-gray-100"></div>
                        <a href="{link Sign:out}" class="block px-5 py-3.5 text-[11px] font-bold tracking-[0.15em] uppercase text-gray-400 hover:bg-gray-50 transition-colors">Logout</a>
                    </div>
                </div>
                {/if}
            {else}
                <a href="{link Sign:in}" class="text-[11px] font-bold tracking-[0.2em] uppercase hover:opacity-40 transition-opacity">Sign In</a>
            {/if}
        </div>
    </nav>
</header>

<!-- Search overlay -->
<div id="search-overlay" class="fixed inset-0 z-[100] bg-white hidden flex-col">
    <div class="max-w-2xl mx-auto w-full px-6 pt-24 pb-6">
        <div class="flex items-center gap-4 border-b-2 border-black pb-3">
            <svg class="w-5 h-5 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/>
            </svg>
            <input id="search-input" type="text" placeholder="Search for shoes…"
                   class="flex-1 text-xl font-light tracking-wide focus:outline-none placeholder-gray-300">
            <button id="search-close" class="text-xs font-bold tracking-widest uppercase text-gray-400 hover:text-black transition-colors flex-shrink-0">
                Close
            </button>
        </div>
        <div id="search-results" class="mt-8 space-y-2"></div>
        <p id="search-hint" class="mt-8 text-xs text-gray-400 tracking-wider">Type to search across all products</p>
    </div>
</div>

{* Flash messages *}
{foreach $flashes as $flash}
<div n:class="'fixed top-20 left-1/2 -translate-x-1/2 z-[90] px-8 py-3 shadow-lg text-white text-[11px] font-bold tracking-widest uppercase',
    $flash->type === 'success' ? 'bg-black' : ($flash->type === 'error' ? 'bg-red-600' : 'bg-gray-600')"
     id="flash-{$iterator->counter}">
    {$flash->message}
</div>
{/foreach}

<main class="flex-1 pt-16">
    {include content}
</main>

{block footer}<footer class="border-t border-gray-100 mt-24">
    <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-4 gap-12">
        <div class="md:col-span-1">
            <p class="text-2xl font-black tracking-[0.35em] mb-4">SPHERE</p>
            <p class="text-sm text-gray-400 leading-relaxed">Premium footwear, delivered with care.</p>
        </div>
        <div>
            <h4 class="text-[11px] font-bold tracking-[0.25em] uppercase mb-5 text-gray-900">Shop</h4>
            <ul class="space-y-3">
                <li><a href="{link Men:default}" class="text-sm text-gray-500 hover:text-black transition-colors">Men</a></li>
                <li><a href="{link Women:default}" class="text-sm text-gray-500 hover:text-black transition-colors">Women</a></li>
            </ul>
        </div>
        <div>
            <h4 class="text-[11px] font-bold tracking-[0.25em] uppercase mb-5 text-gray-900">Support</h4>
            <p class="text-sm text-gray-500 leading-relaxed">Client advisors available<br>Mon–Sat, 6am – 4pm</p>
        </div>
        <div>
            <h4 class="text-[11px] font-bold tracking-[0.25em] uppercase mb-5 text-gray-900">We Accept</h4>
            <div class="flex gap-3 items-center flex-wrap">
                <img src="/images/cc-visa-brands.svg" alt="Visa" class="h-5 opacity-60">
                <img src="/images/cc-mastercard-brands.svg" alt="Mastercard" class="h-5 opacity-60">
                <img src="/images/cc-paypal-brands.svg" alt="PayPal" class="h-5 opacity-60">
                <img src="/images/cc-applepay-brands.svg" alt="Apple Pay" class="h-5 opacity-60">
            </div>
            <p class="text-sm text-gray-500 mt-4 leading-relaxed">Free shipping & returns<br>on all orders.</p>
        </div>
    </div>
    <div class="border-t border-gray-100 py-5 text-center text-xs text-gray-300 tracking-widest">
        &copy; 2026 SPHERE. All rights reserved.
    </div>
</footer>

<script>
    // Flash messages auto-dismiss
    document.querySelectorAll('[id^="flash-"]').forEach(el => {
        setTimeout(() => { el.style.transition = 'opacity 0.5s'; el.style.opacity = '0'; }, 3000);
        setTimeout(() => el.remove(), 3500);
    });

    // Dropdown menus
    function initDropdown(btnId, menuId) {
        const btn = document.getElementById(btnId);
        const menu = document.getElementById(menuId);
        if (!btn || !menu) return;
        btn.addEventListener('click', e => { e.stopPropagation(); menu.classList.toggle('hidden'); });
        document.addEventListener('click', () => menu.classList.add('hidden'));
    }
    initDropdown('user-menu-btn', 'user-menu');
    initDropdown('admin-menu-btn', 'admin-menu');

    // Logo: smooth scroll on homepage, navigate elsewhere
    const logoLink = document.getElementById('logo-link');
    if (logoLink) {
        logoLink.addEventListener('click', e => {
            if (window.location.pathname === '/' || window.location.pathname === '') {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        });
    }

    // Search overlay
    const searchBtn = document.getElementById('search-btn');
    const searchClose = document.getElementById('search-close');
    const searchOverlay = document.getElementById('search-overlay');
    const searchInput = document.getElementById('search-input');
    const searchResults = document.getElementById('search-results');
    const searchHint = document.getElementById('search-hint');

    function openSearch() {
        searchOverlay.classList.remove('hidden');
        searchOverlay.classList.add('flex');
        searchInput.focus();
        document.body.style.overflow = 'hidden';
    }
    function closeSearch() {
        searchOverlay.classList.add('hidden');
        searchOverlay.classList.remove('flex');
        searchInput.value = '';
        searchResults.innerHTML = '';
        searchHint.classList.remove('hidden');
        document.body.style.overflow = '';
    }

    if (searchBtn) searchBtn.addEventListener('click', openSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSearch(); });

    // Search: collect all product cards from the page
    function getProducts() {
        return [...document.querySelectorAll('[data-product-name]')].map(el => ({
            name: el.dataset.productName,
            price: el.dataset.productPrice,
            href: el.dataset.productHref,
            img: el.dataset.productImg,
        }));
    }

    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const q = this.value.trim().toLowerCase();
            searchResults.innerHTML = '';
            if (!q) { searchHint.classList.remove('hidden'); return; }
            searchHint.classList.add('hidden');
            const products = getProducts();
            const matches = products.filter(p => p.name.toLowerCase().includes(q));
            if (matches.length === 0) {
                searchResults.innerHTML = '<p class="text-sm text-gray-400">No results for "' + q + '".</p>';
                return;
            }
            matches.forEach(p => {
                const a = document.createElement('a');
                a.href = p.href;
                a.className = 'flex items-center gap-4 py-3 border-b border-gray-50 hover:bg-gray-50 transition-colors px-2 -mx-2';
                a.innerHTML = '<img src="' + p.img + '" alt="" class="w-12 h-12 object-contain bg-gray-50 flex-shrink-0 p-1">'
                    + '<div><p class="text-sm font-bold">' + p.name + '</p><p class="text-xs text-gray-500 mt-0.5">' + p.price + ' \u20ac</p></div>';
                searchResults.appendChild(a);
            });
        });
    }
</script>
</body>
</html>
