<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 — SPHERE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Roboto', 'Helvetica Neue', Arial, sans-serif; }</style>
</head>
<body class="bg-white text-black min-h-screen flex flex-col items-center justify-center">
    <a href="/" class="text-2xl font-black tracking-[0.35em] mb-16 hover:opacity-50 transition-opacity">SPHERE</a>
    <div class="text-center px-6">
        <p class="text-xs font-bold tracking-[0.4em] uppercase text-gray-400 mb-4">Server Error</p>
        <h1 class="text-8xl font-black mb-6">500</h1>
        <p class="text-sm text-gray-500 mb-10 max-w-sm">Something went wrong on our end. Please try again in a moment.</p>
        <a href="/" class="text-xs font-bold tracking-[0.3em] uppercase border border-black px-8 py-3 hover:bg-black hover:text-white transition-colors">
            Back to Home
        </a>
    </div>
</body>
</html>
